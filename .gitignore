# --- Project Specific (Keep your code clean) ---
bin/
out/
build/
.gradle/

# --- Minecraft/Forge Run Directories ---
# This ignores the test worlds and logs generated when you click 'Run Client'
run/
run-*/
logs/
*.log
usercache.json
usernamecache.json

# --- IDEs (IntelliJ & Eclipse) ---
.idea/
*.ipr
*.iws
*.iml
.settings/
.metadata/
.classpath
.project
*.launch
eclipse/

# --- Gradle Wrapper ---
# We ignore the wrapper's local data, but usually keep the wrapper itself
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat

# --- Forge MDK Cleanup ---
# These are the text files that come with the download but aren't part of your mod
forge_README.txt
forge*changelog.txt
CREDITS.txt
LICENSE.txt

# --- OS Specific ---
.DS_Store
Thumbs.db